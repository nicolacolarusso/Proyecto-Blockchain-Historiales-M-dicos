# Dependencias de JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archivos de sistema (Mac)
.DS_Store
.AppleDouble
.LSOverride

# Variables de entorno (¡Seguridad!)
.env
.env.local

# Build output
frontend/dist/

# SQLite database
backend/data/
*.sqlite

# Credenciales de servicios externos (NUNCA subir al repo)
firebase-service-account.json
backend/firebase-service-account.json

# Fabric wallet (regenerated on startup)
backend/wallet/

# Fabric CA databases (regenerated by networkUp.sh)
blockchain/network/organizations/fabric-ca/*/*.db

# Fabric CA generated keystores (regenerated by networkUp.sh)
blockchain/network/organizations/fabric-ca/*/msp/keystore/*_sk
blockchain/network/organizations/ordererOrganizations/*/msp/keystore/*_sk
blockchain/network/organizations/ordererOrganizations/*/orderers/*/msp/keystore/*_sk
blockchain/network/organizations/ordererOrganizations/*/orderers/*/tls/keystore/*_sk
blockchain/network/organizations/ordererOrganizations/*/users/*/msp/keystore/*_sk
blockchain/network/organizations/peerOrganizations/*/msp/keystore/*_sk
blockchain/network/organizations/peerOrganizations/*/peers/*/msp/keystore/*_sk
blockchain/network/organizations/peerOrganizations/*/peers/*/tls/keystore/*_sk
blockchain/network/organizations/peerOrganizations/*/users/*/msp/keystore/*_sk